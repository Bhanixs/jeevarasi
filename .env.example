# Admin Panel Configuration
# Copy this file to .env and fill in your values

# Admin credentials for accessing the media manager
ADMIN_EMAIL=admin@jeevarsi.org
ADMIN_PASSWORD=Jeevarsi@2025

# Supabase configuration
# Get these from Supabase Dashboard > Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON=your_anon_key_here
SUPABASE_SERVICE=your_service_role_key_here

# ── Email notifications (contact form) ──────────────────────
# Sign up free at https://resend.com — 3,000 emails/month free
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Where to send notifications (defaults to info@jeevarsi.org)
NOTIFY_EMAIL=info@jeevarsi.org
# "From" address (must be a verified domain in Resend)
NOTIFY_FROM=Jeevarasi Website <noreply@jeevarsi.org>

# ── WhatsApp notifications (contact form) ────────────────────
# Sign up at https://twilio.com — activate WhatsApp Sandbox for testing
# Production requires a WhatsApp Business Account approved by Meta
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Admin's WhatsApp number to receive notifications
ADMIN_WHATSAPP_TO=whatsapp:+919842829770
